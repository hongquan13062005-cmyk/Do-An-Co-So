<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Jurni</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

</head>

<body>

<nav class="navbar navbar-expand-lg navbar-light bg-light">

<div class="container">

<a class="navbar-brand" href="/">🌍 Jurni Travel</a>

<ul class="navbar-nav ms-auto">

<li class="nav-item">
<a class="nav-link" href="/">Trang chủ</a>
</li>

<li class="nav-item">
<a class="nav-link" href="/Tour">Tour</a>
</li>

<li class="nav-item">
<a class="nav-link">Liên hệ</a>
</li>

</ul>

</div>

</nav>

<div class="container mt-4">

@RenderBody()
@if(Context.Session.GetString("username") != null)
{
<span>Xin chào @Context.Session.GetString("username")</span>
<a href="/Account/Logout">Đăng xuất</a>
}
else
{
<a href="/Account/Login">Đăng nhập</a>
}
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>