else if (id == 5)
{
<div id="sapaCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
<div class="carousel-inner">

<div class="carousel-item active">
<img src="https://static.vinwonders.com/production/Sapa-rice-fields-banner.jpg" class="d-block w-100 rounded" style="height:450px;object-fit:cover;">
</div>

<div class="carousel-item">
<img src="https://asianwaytravel.com/wp-content/uploads/2018/10/sapa-town-pretty.jpg" class="d-block w-100 rounded" style="height:450px;object-fit:cover;">
</div>

<div class="carousel-item">
<img src="https://asianwaytravel.com/wp-content/uploads/2022/07/sapa-3553138_1920.jpg" class="d-block w-100 rounded" style="height:450px;object-fit:cover;">
