</div>

<!-- MÔ TẢ -->
<div class="col-md-6">

@if (id == 1)
{
<h2>🏝 Tour Đà Nẵng</h2>
<p>Khám phá Bà Nà Hills, Cầu Vàng và biển Mỹ Khê – những điểm đến nổi tiếng nhất của thành phố biển xinh đẹp.</p>
<p>⏱ 3 ngày 2 đêm</p>
<p>💰 3.000.000 VNĐ</p>
}

else if (id == 2)
{
<h2>🌸 Tour Đà Lạt</h2>
<p>Thành phố ngàn hoa với Hồ Xuân Hương thơ mộng và Thung Lũng Tình Yêu lãng mạn.</p>
<p>⏱ 3 ngày 2 đêm</p>
<p>💰 2.800.000 VNĐ</p>
}

else if (id == 3)
{
<h2>🏖 Tour Phú Quốc</h2>
<p>Thiên đường biển đảo với bãi Sao tuyệt đẹp và khu vui chơi VinWonders.</p>
<p>⏱ 4 ngày 3 đêm</p>
<p>💰 4.500.000 VNĐ</p>
}

else if (id == 4)
{
<h2>🌊 Tour Nha Trang</h2>
<p>Khám phá biển Nha Trang, Vinpearl Land và tháp Bà Ponagar nổi tiếng.</p>
<p>⏱ 3 ngày 2 đêm</p>
<p>💰 3.200.000 VNĐ</p>
}

else if (id == 5)
{
<h2>⛰ Tour Sa Pa</h2>
<p>Chinh phục Fansipan và chiêm ngưỡng ruộng bậc thang hùng vĩ.</p>
<p>⏱ 3 ngày 2 đêm</p>
<p>💰 3.500.000 VNĐ</p>
}

else if (id == 6)
{
<h2>🚢 Tour Hạ Long</h2>
<p>Tham quan vịnh Hạ Long – kỳ quan thiên nhiên thế giới.</p>
<p>⏱ 2 ngày 1 đêm</p>
<p>💰 2.500.000 VNĐ</p>
}

<hr />
<h4 class="mt-3 mb-3">📅 Lịch trình tour</h4>

@if (id == 1)  // Đà Nẵng
{

<div class="border rounded p-3 mb-3 bg-light">
<h5 class="text-primary">Ngày 1</h5>
<ul class="mb-0">
<li>Khởi hành đến Đà Nẵng</li>
<li>Tham quan biển Mỹ Khê</li>
<li>Ăn tối hải sản</li>
</ul>
</div>

<div class="border rounded p-3 mb-3 bg-light">
<h5 class="text-success">Ngày 2</h5>
<ul class="mb-0">
<li>Tham quan Bà Nà Hills</li>
<li>Check-in Cầu Vàng</li>
<li>Tham quan làng Pháp</li>
</ul>
</div>

<div class="border rounded p-3 mb-3 bg-light">
<h5 class="text-danger">Ngày 3</h5>
<ul class="mb-0">
<li>Check-in Cầu Rồng</li>
<li>Mua đặc sản Đà Nẵng</li>
<li>Kết thúc tour</li>
</ul>
</div>
}

else if (id == 2)  // Đà Lạt
{

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 1</h5>
<ul class="mb-0">
<li>Di chuyển đến Đà Lạt</li>
<li>Check-in Hồ Xuân Hương</li>
<li>Dạo chợ đêm Đà Lạt</li>
</ul>
</div>

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 2</h5>
<ul class="mb-0">
<li>Tham quan Thung Lũng Tình Yêu</li>
<li>Vườn hoa Đà Lạt</li>
<li>Uống cà phê săn mây</li>
</ul>
</div>

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 3</h5>
<ul class="mb-0">
<li>Check-in Quảng trường Lâm Viên</li>
<li>Mua đặc sản Đà Lạt</li>
<li>Kết thúc tour</li>
</ul>
</div>
}

else if (id == 3)  // Phú Quốc
{

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 1</h5>
<ul class="mb-0">
<li>Bay đến Phú Quốc</li>
<li>Nhận phòng khách sạn</li>
<li>Dạo biển buổi tối</li>
</ul>
</div>

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 2</h5>
<ul class="mb-0">
<li>Tắm biển Bãi Sao</li>
<li>Chơi VinWonders</li>
<li>Ăn tối hải sản</li>
</ul>
</div>

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 3</h5>
<ul class="mb-0">
<li>Đi cáp treo Hòn Thơm</li>
<li>Check-in Sunset Town</li>
</ul>
</div>

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 4</h5>
<ul class="mb-0">
<li>Dạo chợ đêm Phú Quốc</li>
<li>Mua đặc sản</li>
<li>Kết thúc tour</li>
</ul>
</div>
}

else if (id == 4)  // Nha Trang
{

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 1</h5>
<ul class="mb-0">
<li>Di chuyển đến Nha Trang</li>
<li>Tắm biển Nha Trang</li>
<li>Ăn tối hải sản</li>
</ul>
</div>

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 2</h5>
<ul class="mb-0">
<li>Tham quan VinWonders</li>
<li>Check-in Tháp Bà Ponagar</li>
</ul>
</div>

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 3</h5>
<ul class="mb-0">
<li>Check-in Quảng trường 2/4</li>
<li>Mua đặc sản Nha Trang</li>
<li>Kết thúc tour</li>
</ul>
</div>
}

else if (id == 5)  // Sa Pa
{

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 1</h5>
<ul class="mb-0">
<li>Di chuyển đến Sa Pa</li>
<li>Tham quan bản Cát Cát</li>
<li>Dạo chợ đêm Sa Pa</li>
</ul>
</div>

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 2</h5>
<ul class="mb-0">
<li>Chinh phục Fansipan</li>
<li>Ngắm ruộng bậc thang</li>
</ul>
</div>

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 3</h5>
<ul class="mb-0">
<li>Check-in nhà thờ đá Sa Pa</li>
<li>Mua đặc sản Tây Bắc</li>
<li>Kết thúc tour</li>
</ul>
</div>
}

else if (id == 6)  // Hạ Long
{

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 1</h5>
<ul class="mb-0">
<li>Di chuyển đến Hạ Long</li>
<li>Du thuyền tham quan vịnh</li>
<li>Khám phá hang Sửng Sốt</li>
<li>Nghỉ đêm trên du thuyền</li>
</ul>
</div>

<div class="border rounded p-3 mb-3 bg-light">
<h5>Ngày 2</h5>
<ul class="mb-0">
<li>Ngắm bình minh trên vịnh</li>
<li>Tham quan đảo Ti Tốp</li>
<li>Kết thúc tour</li>
</ul>
</div>
}

<div class="mt-4 d-flex gap-2">
<a href="/Tour/Booking" class="btn btn-success">🧳 Đặt Tour</a>
<a href="/Tour/Places/@ViewBag.Id" class="btn btn-primary">📍 Địa điểm ăn chơi</a>
<a href="/Tour" class="btn btn-outline-secondary">⬅ Quay lại</a>
</div>
